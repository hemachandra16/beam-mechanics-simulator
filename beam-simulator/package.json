{
  "name": "beam-mechanics-simulator",
  "version": "2.0.0",
  "description": "Professional Beam Mechanics Simulation Software",
  "main": "main.js",
  "author": "Beam Simulator Team",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.beamsim.app",
    "productName": "Beam Mechanics Simulator",
    "win": {
      "target": "nsis",
      "icon": null
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": true,
      "shortcutName": "Beam Mechanics Simulator"
    },
    "files": [
      "main.js",
      "frontend/**/*"
    ],
    "extraResources": [
      {
        "from": "dist_backend/flask_backend.exe",
        "to": "flask_backend.exe"
      }
    ],
    "asar": true
  }
}
